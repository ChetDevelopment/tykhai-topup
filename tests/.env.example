# Ty Khai TopUp - Test Environment Configuration
# Copy this file to .env.test and update values

# Test Environment
NODE_ENV=test
TEST_BASE_URL=http://localhost:3000

# Admin Credentials (for admin API tests)
TEST_ADMIN_EMAIL=admin@tykhai.com
TEST_ADMIN_PASSWORD=admin123

# Database (test database - should be separate from production)
DATABASE_URL=postgresql://user:password@localhost:5432/tykhai_test

# Payment Configuration (simulation mode for tests)
PAYMENT_SIMULATION_MODE=true
ENABLE_DEV_BAKONG=true

# Redis (for rate limiting tests)
REDIS_URL=redis://localhost:6379

# API Security
NEXTAUTH_SECRET=test-secret-key-for-testing-only
NEXTAUTH_URL=http://localhost:3000

# Feature Flags
TEST_MODE=true
