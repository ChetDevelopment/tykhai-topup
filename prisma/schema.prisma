// Prisma schema for Ty Khai TopUp
// Production: PostgreSQL on Neon
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  publisher   String
  description String?
  imageUrl    String
  bannerUrl   String?
  currencyName String
  uidLabel    String   @default("Player ID")
  uidExample  String?
  requiresServer Boolean @default(false)
  servers     String    @default("[]")
  featured    Boolean   @default(false)
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  seoTitle       String?
  seoDescription String?
  products    Product[]
  orders      Order[]
  savedUids   SavedUid[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([active, featured, sortOrder])
  @@index([active, slug])
}

model Product {
  id              String   @id @default(cuid())
  gameId          String
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name            String
  amount          Int
  bonus           Int      @default(0)
  priceUsd        Float
  resellerPriceUsd Float?
  officialPriceUsd Float?
  priceKhr        Float?
  salePriceUsd     Float?
  saleEndsAt       DateTime?
  isMysteryBox    Boolean  @default(false)
  isSubscriptionAvailable Boolean @default(false)
  badge           String?
  imageUrl        String?
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  // GameDrop integration
  gameDropOfferId Int?    // Maps to GameDrop offer ID for auto-delivery
  // G2Bulk integration (for Free Fire SG/MY)
  g2bulkCatalogueName String? // Maps to G2Bulk catalogue name (e.g., "100", "310")
  orders          Order[]
  reviews         Review[]
  rewards         MysteryBoxReward[]
  wishlists       Wishlist[]
  priceAlerts     PriceAlert[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([gameId, active])
  @@unique([gameId, name])
}

model Order {
  id                 String       @id @default(cuid())
  orderNumber        String       @unique
  gameId             String
  game               Game         @relation(fields: [gameId], references: [id])
  productId          String
  product            Product      @relation(fields: [productId], references: [id])
  playerUid          String
  serverId           String?
  playerNickname     String?
  customerEmail      String?
  customerPhone      String?
  amountUsd          Float
  amountKhr          Float?
  currency           String       @default("USD")
  paymentMethod      String
  paymentRef         String?
  paymentRefEnc      String?
  paymentUrl         String?
  qrString           String?
  paymentExpiresAt   DateTime?
  status             String       @default("PENDING")
  deliveryStatus     String?      // QUEUED, DELIVERING, DELIVERED, FAILED_RETRY, FAILED_FINAL
  deliveryNote       String?
  failureReason      String?
  // Distributed locking
  lockUntil          DateTime?    // Lock expiration time
  lockedBy           String?      // Process identifier holding the lock
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  paidAt             DateTime?
  deliveredAt        DateTime?
  promoCodeId        String?
  promoCode          PromoCode?  @relation(fields: [promoCodeId], references: [id])
  discountUsd        Float        @default(0)
  pointsEarned       Int          @default(0)
  pointsUsed         Int          @default(0)
  isSubscription     Boolean      @default(false)
  squadPoolId        String?
  squadPool          SquadPool?   @relation(fields: [squadPoolId], references: [id])

  deliveryAttempts  Int          @default(0)
  maxDeliveryAttempts Int          @default(3)
  lastDeliveryAt    DateTime?
  nextDeliveryAt    DateTime?
  walletReserved    Float        @default(0)
  refundStatus      String?
  refundReason      String?
  refundAmount      Float?
  refundAt          DateTime?
  fraudScore        Float        @default(0)
  fraudFlags        String       @default("[]")
  idempotencyKey    String?      @unique

  userId             String?
  user               User?        @relation(fields: [userId], references: [id], name: "OrderUser")
  review             Review?
  tickets            Ticket[]
  paymentLogs        PaymentLog[]
  deliveryLogs      DeliveryLog[]
  deliveryJobs      DeliveryJob[]
  refunds            Refund[]       @relation("OrderRefunds")
  walletReservations WalletReservation[] @relation("OrderWalletReservations")
  fraudFlags2       FraudFlag[]    @relation("OrderFraudFlags")
  metadata           Json         @default("{}")

  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
}

model PaymentLog {
  id                String   @id @default(cuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event             String
  status            String
  paymentRef        String?
  amount            Float?
  currency          String?
  provider          String?
  responseCode      String?
  responseMessage   String?
  rawResponse       String?
  metadata         Json   @default("{}")
  createdAt         DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model DeliveryLog {
  id                String   @id @default(cuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attemptNumber     Int      @default(1)
  status            String
  deliveryMethod    String?
  requestPayload    String?
  responsePayload   String?
  errorMessage      String?
  durationMs        Int?
  nextRetryAt       DateTime?
  createdAt         DateTime @default(now())

  @@index([orderId])
  @@index([status])
}

// Queue-based delivery job system
// Jobs are enqueued when order becomes PAID, processed asynchronously by worker
model DeliveryJob {
  id                String   @id @default(cuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status            String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, RETRYING
  attempt           Int      @default(0)
  maxAttempts       Int      @default(3)
  nextAttemptAt     DateTime? // When to retry (exponential backoff)
  startedAt         DateTime?
  completedAt       DateTime?
  errorMessage      String?
  providerResponse  String?   // JSON from GameDrop/G2Bulk
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([orderId, status])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  adminEmail String?
  action      String
  targetType String?
  targetId    String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId])
}

model Refund {
  id              String   @id @default(cuid())
  orderId         String
  order           Order     @relation("OrderRefunds", fields: [orderId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?     @relation("UserRefunds", fields: [userId], references: [id])
  amount          Float
  currency        String   @default("USD")
  reason          String?
  status          String   @default("PENDING")
  refundMethod    String?
  transactionId   String?
  processorFee    Float?
  netAmount       Float?
  requestedAt     DateTime @default(now())
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([orderId])
}

model WalletReservation {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserWalletReservations", fields: [userId], references: [id], onDelete: Cascade)
  orderId         String?
  order           Order?    @relation("OrderWalletReservations", fields: [orderId], references: [id])
  amount          Float
  currency        String   @default("USD")
  status          String   @default("ACTIVE")
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([status])
}

model FraudFlag {
  id              String   @id @default(cuid())
  orderId         String?
  order           Order?    @relation("OrderFraudFlags", fields: [orderId], references: [id])
  userId          String?
  user            User?    @relation("UserFraudFlags", fields: [userId], references: [id])
  type            String
  severity        String   @default("MEDIUM")
  description     String?
  metadata        Json?
  isResolved      Boolean  @default(false)
  resolvedById    String?
  resolvedBy      User?    @relation("FraudResolver", fields: [resolvedById], references: [id])
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([isResolved])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String
  discountValue Float
  minOrderUsd   Float     @default(0)
  maxUses       Int       @default(0)
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String    @default("ADMIN")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?
}

model Settings {
  id          Int      @id @default(1)
  siteName    String   @default("Ty Khai TopUp")
  exchangeRate Float   @default(4100)
  supportTelegram String? @default("@Vichet_SAT")
  supportEmail String? @default("support@tykhai.com")
  maintenanceMode Boolean @default(false)
  maintenanceMessage String?
  announcement String?
  announcementTone String? @default("info")
  popupActive      Boolean @default(false)
  popupTitle       String?
  popupContent     String?
  popupImageUrl     String?
  telegramBotToken String?
  telegramChatId   String?
  updatedAt   DateTime @updatedAt

  // System Control
  systemStatus      String   @default("ACTIVE")
  pauseReason       String?
  systemMode        String   @default("AUTO")

  // Balance Monitoring
  balanceCheckInterval Int     @default(5)
  warningThreshold  Float?   @default(20.0)
  criticalThreshold Float?   @default(5.0)
  lastBalanceCheck  DateTime?
  currentBalance    Float?
  reservedBalance   Float    @default(0)
  alertCooldownMinutes Int   @default(15)
  lastAlertSentAt   DateTime?
  gameDropToken     String?
  gameDropPartnerId Int?
  g2bulkToken       String?
  g2bulkPartnerId   Int?
}

model BalanceLog {
  id        String   @id @default(cuid())
  balance    Float
  reserved   Float    @default(0)
  available  Float
  threshold  String?
  source     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model HeroBanner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  ctaLabel  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
  @@index([active, createdAt])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  active    Boolean   @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String
  coverUrl    String?
  tag         String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

model BlockedIdentity {
  id        String   @id @default(cuid())
  type      String
  value     String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([type, value])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          String    @default("USER")
  pointsBalance Int       @default(0)
  walletBalance Float     @default(0)
  totalSpentUsd Float     @default(0)
  vipRank       String    @default("BRONZE")
  resellerTier  String?
  resellerDiscount Float   @default(0)
  parentResellerId String?
  parentReseller   User?  @relation("ResellerNetwork", fields: [parentResellerId], references: [id])
  subResellers    User[]  @relation("ResellerNetwork")
  referredById   String?
  referredBy    User?     @relation("ReferralNetwork", fields: [referredById], references: [id])
  referrer      User[]    @relation("ReferralNetwork")
  referralEarnings Float   @default(0)
  pushSubscription String?
  accounts      Account[]
  sessions      Session[]
  savedUids     SavedUid[]
  orders        Order[]    @relation("OrderUser")
  points        PointTransaction[]
  subscriptions Subscription[]
  tickets       Ticket[]  @relation("UserTickets")
  refunds            Refund[]           @relation("UserRefunds")
  walletReservations WalletReservation[] @relation("UserWalletReservations")
  fraudFlags        FraudFlag[]        @relation("UserFraudFlags")
  resolvedFlags     FraudFlag[]        @relation("FraudResolver")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model SavedUid {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  playerUid String
  user      User     @relation(fields: [userId], references: [id])
  game      Game     @relation(fields: [gameId], references: [id])
  createdAt DateTime @default(now())
  @@unique([userId, gameId, playerUid])
}

model Review {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  rating      Int      @default(5)
  comment     String?
  customerName String
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  type      String
  orderId   String?
  createdAt DateTime @default(now())
}

model SquadPool {
  id          String   @id @default(cuid())
  productId   String
  leaderId    String
  targetSize  Int      @default(5)
  currentSize Int      @default(1)
  status      String   @default("OPEN")
  expiresAt   DateTime
  orders      Order[]
  createdAt   DateTime @default(now())
}

model MysteryBoxReward {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  amount      Int
  probability Float
  isJackpot   Boolean  @default(false)
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId      String
  productId   String
  intervalDays Int      @default(7)
  nextRunAt   DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  product    Product   @relation(fields: [productId], references: [id])
  createdAt DateTime  @default(now())
  @@unique([userId, productId])
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  targetPrice Float
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
  @@unique([userId, productId])
}

model Bundle {
  id          String    @id @default(cuid())
  name        String
  description String?
  products    String
  bundlePrice Float
  originalPrice Float
  badge       String?
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SpinWin {
  id          String   @id @default(cuid())
  userId     String
  prize      String
  prizeValue Int
  won        Boolean  @default(true)
  claimed    Boolean  @default(false)
  createdAt  DateTime  @default(now())
}

model Ticket {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation("UserTickets", fields: [userId], references: [id])
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id])
  subject     String
  category    String
  status      String    @default("OPEN")
  priority    String    @default("NORMAL")
  message     String
  response    String?
  adminId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}
