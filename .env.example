# PostgreSQL connection string
# Use any Postgres provider: Supabase, Neon, Railway, or local
DATABASE_URL="postgresql://user:password@localhost:5432/rithtopup?schema=public"

# JWT secret for admin auth (generate: openssl rand -base64 32)
JWT_SECRET="change-this-to-a-long-random-string-at-least-32-chars"

# Admin bootstrap (used on first db:seed)
ADMIN_EMAIL="admin@gmail.com"
ADMIN_PASSWORD="admin123"

# Cron job secret for background workers (generate: openssl rand -hex 32)
CRON_SECRET="your-cron-secret-here"

# Base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Public URL for payment gateway callbacks (KHPay rejects localhost/private IPs).
# Local dev: use a tunnel → cloudflared tunnel --url http://localhost:3000
# Production: set to your real https domain.
PUBLIC_APP_URL="https://tykhai.vercel.app"

# Bakong API Base URL
BAKONG_API_BASE="https://merchant-qr.bakong.org.kh"

# Simulation mode: when "true", payments auto-complete after 3s (for dev/demo)
PAYMENT_SIMULATION_MODE="false"

# SMTP Settings for Order Receipt Emails
# Use Gmail, SendGrid, Mailgun, or any SMTP provider
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# GameDrop API Token (for GameDrop delivery)
GAMEDROP_TOKEN="your_gamedrop_token"

# G2Bulk API Configuration (for Free Fire SG/MY)
G2BULK_TOKEN="your_g2bulk_token"
G2BULK_API_BASE="https://api.g2bulk.com/v1"

# ABA PayWay Configuration (Cambodia Payment Gateway)
# Get credentials from https://developer.payway.com.kh/
ABA_PAYWAY_API="https://checkout.payway.com.kh"
ABA_MERCHANT_ID="your_merchant_id"
ABA_SECRET_KEY="your_secret_key"
ABA_PUBLIC_KEY="your_public_key"
