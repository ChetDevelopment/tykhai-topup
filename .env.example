# PostgreSQL connection string
# Use any Postgres provider: Supabase, Neon, Railway, or local
DATABASE_URL="postgresql://user:password@localhost:5432/rithtopup?schema=public"

# JWT secret for admin auth (generate: openssl rand -base64 32)
JWT_SECRET="change-this-to-a-long-random-string-at-least-32-chars"

# Admin bootstrap (used on first db:seed)
ADMIN_EMAIL="admin@gmail.com"
ADMIN_PASSWORD="admin123"

# Base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Public URL for payment gateway callbacks (KHPay rejects localhost/private IPs).
# Local dev: use a tunnel → cloudflared tunnel --url http://localhost:3000
# Production: set to your real https domain.
PUBLIC_APP_URL=""

# Simulation mode: when "true", payments auto-complete after 3s (for dev/demo)
PAYMENT_SIMULATION_MODE="true"

# SMTP Settings for Order Receipt Emails
# Use Gmail, SendGrid, Mailgun, or any SMTP provider
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
